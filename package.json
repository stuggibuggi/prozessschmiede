{
  "name": "prozessschmiede",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --filter ./apps/* dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint",
    "test": "corepack pnpm -r --if-present test",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "format": "corepack pnpm -r --if-present format",
    "db:generate": "corepack pnpm --filter api prisma:generate",
    "db:migrate": "corepack pnpm --filter api prisma:migrate",
    "db:push": "corepack pnpm --filter api prisma:push",
    "db:seed": "corepack pnpm --filter api db:seed",
    "db:reset": "corepack pnpm --filter api db:reset"
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "typescript": "^5.6.3"
  }
}
