    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/**/*.test.ts",
    "format": "echo \"No formatter configured\"",
    "prisma:generate": ".\\node_modules\\.bin\\dotenv.CMD -e ../../.env -- prisma generate",
    "prisma:migrate": ".\\node_modules\\.bin\\dotenv.CMD -e ../../.env -- prisma migrate dev",
    "prisma:push": ".\\node_modules\\.bin\\dotenv.CMD -e ../../.env -- prisma db push",
    "db:seed": ".\\node_modules\\.bin\\dotenv.CMD -e ../../.env -- tsx prisma/seed.ts",
    "db:reset": ".\\node_modules\\.bin\\dotenv.CMD -e ../../.env -- prisma migrate reset --force && .\\node_modules\\.bin\\dotenv.CMD -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
